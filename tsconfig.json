{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Preserve",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "allowJs": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "dist/types",
    "rootDir": "../../src/frontend/components/ai",
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": false
  },
  "include": ["../../src/frontend/components/ai/**/*.ts"],
  "exclude": [
    "../../src/frontend/components/ai/**/*.test.ts",
    "../../src/frontend/components/ai/**/*.stories.ts",
    "../../src/frontend/components/ai/stories/**"
  ]
}
